vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 201
  }
}
classes: @"../../../classes/function"
classes: @"../../../classes/basic"

_quality: {class: compiles}


arr
countingSort: {
  label: countingSort(arr)
  result: {
    label: result\ninit \[0\] * 100
  }
  iterate: {
    label: "for [a, a, a...] in arr"
    class: iter
  }
  increment: {
    label: increment @ i\nresult\[a\] += 1
    class: op
  }
  iterate -> increment -> result
}
arr -> countingSort.iterate
