direction: down
vars: {
  d2-config: {
    theme-id: 201
    layout-engine: elk
  }
}

classes: @"../../../classes/basic"

_quality: {class: compiles}

sticks
maximumPerimeterTriangle {
  sort: sort\ndescending
  iter: i in range(len(sticks)-2)
    cond: isTriangle\nC < B + A {
      shape: diamond
      y: sorted\nedges {
        shape: circle
        style: {
          stroke: darkgreen
        }
      }
      n: \[-1\] {
        shape: circle
        style: {
          stroke: crimson
        }
      }
    }
  result
  sort -> iter
  iter -> cond
  cond.y -> result: {
    style: {
      stroke: darkgreen
    }
  }
  cond.n -> result: {
    style: {
      stroke: crimson
    }
  }
}
sticks -> maximumPerimeterTriangle.sort
