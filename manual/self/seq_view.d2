vars: {
  d2-config: {
    theme-id: 201
  }
}
classes: @"../classes/sequence"
classes: @"../classes/basic"

_quality: {class: compiles}

seq_view: {
  shape: sequence_diagram
  user: {shape: c4-person}
  navigator: {label: "ManualNavigator.tsx\nPointers panel"; class: frontend}
  panel: {label: "D2Panel.tsx"; class: frontend}
  api: {label: "server.js\n:3002"; class: api}
  d2: {label: "d2 CLI"; class: pipeline}
  fs: {label: "manual/"; class: database}

  navigator -> api: "GET /pointers.yaml (poll 2 s)" {class: api}
  navigator -> api: "POST /api/manual/exists" {class: api}
  navigator.note1: |md
    tree from pointers.yaml;
    missing files struck through
  |

  user -> navigator: "tap diagram (or j/k, gg/G, /search)"
  navigator -> panel: "navigate /manual/<path>.d2"
  panel -> api: "POST /api/manual/watch" {class: api}
  api -> d2: "spawn d2 --watch <path>.d2"
  d2 -> fs: "write <path>.svg"
  panel -> api: "GET /api/manual/events (SSE)" {class: api}
  api -> panel: "event: svg updated" {class: api}
  panel -> fs: "GET /manual/<path>.svg"
  panel.note1: |md
    .mmd diagrams skip the server:
    MermaidPanel renders client-side
  |

  user -> panel: "drag / pinch / wheel — pan & zoom"
  user -> panel: "h / l — previous / next layer"
}
