vars: {
  d2-config: {
    # layout-engine: elk
    theme-id: 4
  }
}
classes: {
  response: {
    style: {
      stroke-dash: 5
    }
  }
}
layers: {
  no_auth: {
    shape: sequence_diagram
    browser: {shape: c4-person}
    main_tsx: {label: main.tsx}
    App: {
      label: App.tsx
    }
    Reader: Reader.tsx
    Auth: {
      label: /auth
    }
    api: FastAPI

    browser -> main_tsx: load page
    main_tsx -> App
    App -> Reader: "route /"
    Reader -> api: GET /api/stories
    api -> Reader: "stories[]" {class: response}
    Reader -> api: "GET /api/stories/{id}/sentences?limit=500"
    api -> Reader: "sentences[]" {class: response}
    Reader.note1: |md
      render: 
      * SentenceView
      * WordGloss
      * AudioPlayer
      * Navigation
    |
  }

  auth: {
    shape: sequence_diagram
    browser: {shape: c4-person}
    main_tsx: {label: main.tsx}
    App: {label: App.tsx}
    AuthProvider: {label: "context\nAuthContext\nAuthProvider"}
    Auth: {label: "Auth.tsx\n/auth"}
    Reader: {label: "Reader.tsx\n/"}
    api: FastAPI

    # 1. App boot: session check
    browser -> main_tsx: load page
    main_tsx -> App
    App -> AuthProvider: mount
    AuthProvider -> api: "GET /api/auth/me\n(credentials: include)"
    api -> AuthProvider: "user{} | null" {class: response}
    AuthProvider.note1: |md
      user populated;
      loading → false
    |

    # 2. Navigate to /auth (no token): email form
    App -> Auth: "route /auth"
    Auth.note1: |md
      render email form
    |
    browser -> Auth: submit email
    Auth -> api: "POST /api/auth/request\n{email}"
    api -> Auth: "200 ok" {class: response}
    api.note1: |md
      sends magic-link email
    |
    Auth.note2: |md
      "Check your email…"
    |

    # 3. Click link → verify token
    browser -> Auth: "/auth?token=…"
    Auth -> api: "GET /api/auth/verify?token=…\n(credentials: include)"
    api -> Auth: "200 + Set-Cookie: session" {class: response}
    Auth -> api: "GET /api/auth/me\n(credentials: include)"
    api -> Auth: "user{}" {class: response}
    Auth -> AuthProvider: setUser(user)
    Auth -> browser: navigate /

    # 4. Logout
    Reader -> api: "POST /api/auth/logout\n(credentials: include)"
    api -> Reader: "200; clears cookie" {class: response}
    Reader -> AuthProvider: setUser(null)
  }
}
