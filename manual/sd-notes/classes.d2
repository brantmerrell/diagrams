notes: {
  shape: page
  style: {
    font-size: 26
  }
}
edge_invis: {
  style: {
    stroke-width: 0
  }
}
edge_request: {
  label: rq
  style: {
    font-color: crimson
    stroke-dash: 5
    stroke: black
  }
}
edge_response: {
  label: rsp
  style: {
    font-color: crimson
    stroke-dash: 3
    stroke: deepskyblue
  }
}
edge_write: {
  label: W
  style: {
    font-color: crimson
    stroke-dash: 2
    stroke: green
  }
}
edge_query: {
  label: Q
  style: {
    font-color: crimson
    stroke-dash: 4
    stroke: navy
  }
}
note: {
  shape: page
}
obj_cache: {
  style: {
    font-size: 20
    fill: gold
  }
}
objs_cache: {
  style: {
    font-size: 20
    multiple: true
    fill: goldenrod
  }
}
