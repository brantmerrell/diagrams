shape: sequence_diagram
vars: {
  d2-config: {
    # layout-engine: elk
    theme-id: 4
  }
}
classes: {
  response: {
    style: {
      stroke-dash: 5
    }
  }
}
script: enrich_glosses.py
db: PostgreSQL
azure: Azure Translator

script.note1: |md
  load .env → DATABASE_URL, AZURE_TRANSLATOR_KEY, AZURE_TRANSLATOR_REGION
|
script -> db: psycopg2 connect
db -> script: connection {class: response}
script -> db: "SELECT DISTINCT surface_devanagari, surface_romanized\nFROM sentence_words WHERE lemma_id IS NULL"
db -> script: "unique_words[]" {class: response}

script.note2: |md
  split into batches of 100
|

script -> azure: "POST /translate [batch of devanagari texts, hi→en]"
azure -> script: "translations[]" {class: response}

script -> db: SELECT id FROM lemmas WHERE devanagari = ?
db -> script: lemma row (or empty) {class: response}
script -> db: INSERT lemma (if new)
script -> db: SELECT id FROM word_senses WHERE lemma_id = ? AND english_definition = ?
db -> script: sense row (or empty) {class: response}
script -> db: INSERT word_sense (if new)
script -> db: "UPDATE sentence_words SET lemma_id, word_sense_id\nWHERE surface_devanagari = ? AND lemma_id IS NULL"
script -> db: COMMIT

script.note3: |md
  repeat translate → upsert → commit for each batch
|
