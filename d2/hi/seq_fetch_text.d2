shape: sequence_diagram
vars: {
  d2-config: {
    # layout-engine: elk
    theme-id: 4
  }
}
classes: {
  response: {
    style: {
      stroke-dash: 5
    }
  }
}
user: {shape: person}
script: fetch_text.py
wikisource: Hindi Wikisource
fs: data/raw

user -> script: "python fetch_text.py \"<page title>\""
script.note1: |md
  slugify(page_title) → ASCII slug
  (or codepoint-based slug for pure Devanagari)
|
script -> wikisource: "GET /w/api.php?action=parse&page=<title>&prop=text"
wikisource -> script: rendered HTML {class: response}
script.note2: |md
  BeautifulSoup: strip tables, nav, edit links, footnotes
  extract `<p>` text → NFC normalize → collapse spaces
|
script -> fs: "write <slug>.txt (Devanagari prose)"
script -> fs: "write <slug>.json (title_hi, slug, source_url, author, char_count)"
fs -> user: paths printed to stdout {class: response}
